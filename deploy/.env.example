# Public subdomain the storefront is served on (already resolves via *.ovira.cloud).
SHOP_HOST=shop.ovira.cloud

# Same-origin public base the browser/SSR use for the Frappe API. Keep it equal to
# https://<SHOP_HOST> so cookies and API calls stay same-origin.
FRAPPE_URL=https://shop.ovira.cloud

# The existing Frappe docker network (Traefik + backend live here).
FRAPPE_NETWORK=frappe_docker_default
